{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Trellis",
  "scopeName": "source.trellis",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#frontmatter"
    },
    {
      "include": "#scenario"
    },
    {
      "include": "#steps"
    },
    {
      "include": "#block-keywords"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#dates"
    },
    {
      "include": "#handles"
    },
    {
      "include": "#punctuation"
    }
  ],
  "repository": {
    "block-keywords": {
      "patterns": [
        {
          "name": "keyword.control.trellis",
          "match": "^\\s*(Feature|Provides|Consumes|Invariants|OutOfScope):"
        }
      ]
    },
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.trellis",
          "match": "^\\s*#.*$"
        }
      ]
    },
    "dates": {
      "patterns": [
        {
          "name": "constant.numeric.date.trellis",
          "match": "\\b\\d{4}-\\d{2}-\\d{2}\\b"
        }
      ]
    },
    "frontmatter": {
      "patterns": [
        {
          "name": "meta.frontmatter.trellis",
          "match": "^\\s*(@[A-Za-z][A-Za-z0-9_-]*)(\\s*:)",
          "captures": {
            "1": {
              "name": "entity.other.attribute-name.trellis"
            },
            "2": {
              "name": "punctuation.separator.key-value.trellis"
            }
          }
        }
      ]
    },
    "handles": {
      "patterns": [
        {
          "name": "variable.other.handle.trellis",
          "match": "\\b[A-Za-z][A-Za-z0-9_-]*(?:\\.[A-Za-z][A-Za-z0-9_-]*)*\\b"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.delimiter.trellis",
          "match": "[:,.()\\[\\]-]"
        }
      ]
    },
    "scenario": {
      "patterns": [
        {
          "name": "meta.scenario.trellis",
          "match": "^\\s*(Scenario)(?:\\(([^)]+)\\))?(\\s*:)",
          "captures": {
            "1": {
              "name": "keyword.control.trellis"
            },
            "2": {
              "name": "entity.name.type.scenario-kind.trellis"
            },
            "3": {
              "name": "punctuation.separator.key-value.trellis"
            }
          }
        }
      ]
    },
    "steps": {
      "patterns": [
        {
          "name": "keyword.control.step.trellis",
          "match": "^\\s*(Given|When|Then|And|But)\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.trellis",
          "match": "\"[^\"\\n]*\""
        }
      ]
    }
  }
}
